<div class="kbuilder-container" style="padding: {{ padding }}; background: {{ background }};">
    <div style="max-width: {{ max_width }}; margin: 0 auto; width: 100%;">
        {% if children is iterable %}
            {% for child in children %}
                {{ render_component(child) }}
            {% endfor %}
        {% endif %}
    </div>
</div>
