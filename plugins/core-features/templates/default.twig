<section class="kb-section kb-features" style="padding: 5rem 0;">
    <div class="kb-container">
        
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; color: var(--kb-text-main);">{{ title }}</h2>
            {% if subtitle %}
            <div style="font-size: 1.125rem; color: var(--kb-text-muted); max-width: 600px; margin: 0 auto; line-height: 1.6;">
                {{ subtitle|raw }}
            </div>
            {% endif %}
        </div>

        <div style="display: grid; gap: 2rem; grid-template-columns: repeat(auto-fit, minmax({% if columns == '4' %}240px{% elseif columns == '2' %}400px{% else %}300px{% endif %}, 1fr));">
            {% for item in items %}
            <div class="kb-feature-card" style="padding: 2rem; border-radius: var(--kb-radius-lg); background: var(--kb-bg); border: 1px solid rgba(100, 116, 139, 0.1); box-shadow: var(--kb-shadow-sm); transition: transform 0.3s ease;">
                <div style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: hsla(var(--kb-primary-h, 221), 83%, 53%, 0.1); color: var(--kb-primary); border-radius: var(--kb-radius-md); margin-bottom: 1.5rem;">
                    <!-- Render icon if supported, for now just show text if icon is missing -->
                    <i data-lucide="{{ item.icon }}"></i>
                </div>
                <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--kb-text-main);">{{ item.title }}</h3>
                <div style="color: var(--kb-text-muted); line-height: 1.6;">
                    {{ item.description|raw }}
                </div>
            </div>
            {% endfor %}
        </div>

    </div>
</section>
