<section class="kb-section kb-post-grid" style="padding: 4rem 1rem; background: var(--kb-bg);">
    <div class="kb-container" style="max-width: var(--kb-container); margin: 0 auto;">
        
        {% if props.heading %}
        <h2 style="font-size: 2rem; font-weight: 700; color: var(--kb-text); margin-bottom: 2rem; text-align: center;">
            {{ props.heading }}
        </h2>
        {% endif %}

        {% set gridCols = 4 %}
        {% if props.layout_style == 'grid-2' %} {% set gridCols = 2 %} {% endif %}
        {% if props.layout_style == 'grid-3' %} {% set gridCols = 3 %} {% endif %}

        <div style="display: grid; grid-template-columns: repeat({{ gridCols }}, 1fr); gap: 2rem; align-items: stretch;">
            {% for post in props.items %}
            <article style="background: white; border-radius: var(--kb-radius); overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); display: flex; flex-direction: column; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
                
                <a href="{{ base_url }}/{{ post.slug }}" style="display: block; position: relative; padding-top: 66.66%;">
                    <img src="{{ post.thumbnail ?? 'https://placehold.co/600x400/eee/ccc?text=No+Image' }}" alt="{{ post.title }}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                    <div style="position: absolute; top: 10px; right: 10px; background: var(--kb-primary); color: white; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">
                        {{ props.post_type == 'product' ? 'Sản phẩm' : 'Tin tức' }}
                    </div>
                </a>

                <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
                    <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; line-height: 1.4;">
                        <a href="{{ base_url }}/{{ post.slug }}" style="color: var(--kb-text); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--kb-primary)'" onmouseout="this.style.color='var(--kb-text)'">
                            {{ post.title }}
                        </a>
                    </h3>
                    
                    <p style="color: var(--kb-secondary); font-size: 0.875rem; line-height: 1.5; margin-bottom: 1.5rem; flex-grow: 1;">
                        {{ post.excerpt|default(post.content|striptags|slice(0, 100) ~ '...') }}
                    </p>

                    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #E2E8F0; padding-top: 1rem;">
                        <span style="font-size: 0.75rem; color: var(--kb-secondary);">
                            {{ post.created_at|date("d/m/Y") }}
                        </span>
                        <a href="{{ base_url }}/{{ post.slug }}" style="font-size: 0.875rem; font-weight: 500; color: var(--kb-primary); text-decoration: none;">
                            Xem chi tiết &rarr;
                        </a>
                    </div>
                </div>
            </article>
            {% else %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; background: #f8fafc; border-radius: var(--kb-radius); color: var(--kb-secondary);">
                Không có dữ liệu để hiển thị.
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<style>
    /* Responsive fallback for the inline grid */
    @media (max-width: 1024px) {
        .kb-post-grid > div > div {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
    @media (max-width: 640px) {
        .kb-post-grid > div > div {
            grid-template-columns: 1fr !important;
        }
    }
</style>
