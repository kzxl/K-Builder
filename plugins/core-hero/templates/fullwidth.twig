<section class="kb-hero-fullwidth" style="
    position: relative; 
    min-height: {{ min_height|default('500px') }};
    display: flex;
    align-items: center;
    background-color: {{ bg_color|default('#1e293b') }};
    {% if bg_image %}
    background-image: url('{{ bg_image starts with 'http' ? bg_image : asset_url ~ bg_image }}');
    background-size: cover;
    background-position: center;
    {% endif %}
    text-align: {{ text_align|default('center') }};
    color: white;
">
    <div style="
        position: absolute; inset: 0; 
        background: black; 
        opacity: {{ bg_overlay|default(50) / 100 }};
        z-index: 1;
    "></div>

    <div class="kb-container" style="position: relative; z-index: 2; width: 100%;">
        <div style="max-width: 800px; margin: 0 {% if text_align == 'center' %}auto{% elseif text_align == 'right' %}0 0 auto{% else %}0 auto 0 0{% endif %};">
            
            <h1 style="font-size: 3.5rem; font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1.5rem;">
                {{ title }}
            </h1>
            
            {% if subtitle %}
                <div style="font-size: 1.25rem; opacity: 0.9; margin-bottom: 2.5rem; line-height: 1.6;">
                    {{ subtitle|raw }}
                </div>
            {% endif %}
            
            <div style="display: flex; gap: 1rem; align-items: center; {% if text_align == 'center' %}justify-content: center;{% elseif text_align == 'right' %}justify-content: flex-end;{% else %}justify-content: flex-start;{% endif %}">
                {% if cta_text and cta_url %}
                    <a href="{{ cta_url }}" class="kb-btn kb-btn--lg kb-btn--{{ cta_style|default('primary') }}">
                        {{ cta_text }}
                    </a>
                {% endif %}
                
                {% if cta2_text and cta2_url %}
                    <a href="{{ cta2_url }}" class="kb-btn kb-btn--lg kb-btn--outline" style="color: white; border-color: rgba(255,255,255,0.3);">
                        {{ cta2_text }}
                    </a>
                {% endif %}
            </div>

        </div>
    </div>

    {% if scroll_arrow %}
        <div style="position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 2; animation: kb-bounce 2s infinite;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.7;">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
        </div>
        <style>
            @keyframes kb-bounce {
                0%, 20%, 50%, 80%, 100% { transform: translateY(0) translateX(-50%); }
                40% { transform: translateY(-10px) translateX(-50%); }
                60% { transform: translateY(-5px) translateX(-50%); }
            }
        </style>
    {% endif %}
</section>
