<section class="kb-section kb-gallery" style="padding: var(--kb-section-py, 60px) 1rem; background: var(--kb-bg);">
    <div class="kb-container" style="max-width: var(--kb-container, 1200px); margin: 0 auto;">
        {% if title %}
        <h2 style="text-align:center; font-size:1.75rem; font-weight:700; color:var(--kb-text); margin-bottom:1.5rem;">{{ title }}</h2>
        {% endif %}

        <div style="display:grid; grid-template-columns:repeat({{ columns|default('3') }}, 1fr); gap:{{ gap|default('12px') }};">
            {% for item in items %}
                {% if item.image %}
                <figure style="margin:0;">
                    <img src="{{ item.image }}" alt="{{ item.alt }}" loading="lazy"
                        style="width:100%; height:100%; object-fit:cover; display:block; {% if rounded %}border-radius:var(--kb-radius);{% endif %}">
                    {% if item.caption %}
                    <figcaption style="margin-top:0.5rem; font-size:0.85rem; color:var(--kb-secondary); text-align:center;">{{ item.caption }}</figcaption>
                    {% endif %}
                </figure>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
