{
    "name": "kbuilder/kbuilder",
    "description": "KBuilder — Universal Web Builder Platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0",
        "twig/twig": "^3.7",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^6.10",
        "monolog/monolog": "^3.0",
        "league/flysystem": "^3.0",
        "respect/validation": "^2.2",
        "robmorgan/phinx": "^0.14",
        "predis/predis": "^2.2",
        "ramsey/uuid": "^4.7",
        "nesbot/carbon": "^2.70"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "KBuilder\\": "src/"
        },
        "classmap": [
            "plugins/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "KBuilder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "vendor/bin/phinx migrate",
        "migrate:rollback": "vendor/bin/phinx rollback",
        "seed": "vendor/bin/phinx seed:run",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
