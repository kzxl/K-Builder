# App
APP_NAME="KBuilder"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/kbuilder/public
APP_KEY=change-me-to-a-random-32-char-string
# Ghi log mọi request vào storage/logs/request.log (chỉ bật khi debug)
APP_DEBUG_REQUESTS=false

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kbuilder
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=kb_

# JWT
JWT_SECRET=change-me-to-a-random-secret-key
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=kbuilder_
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Security (kb-security plugin)
SECURITY_API_RATE_LIMIT=120
SECURITY_LOGIN_RATE_LIMIT=8
SECURITY_RATE_WINDOW=60

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=storage/media
UPLOAD_MAX_SIZE=10485760

# Admin
ADMIN_DIST_PATH=apps/admin/dist
