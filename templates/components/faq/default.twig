<section class="kb-section kb-faq-block" style="padding: 4rem 0;">
    <div class="kb-container" style="max-width: 800px;">
        {% if props.title %}
        <h2 class="kb-title" style="text-align: center; margin-bottom: 3rem;">
            {{ props.title }}
        </h2>
        {% endif %}

        <div style="display: flex; flex-direction: column; gap: 1rem;">
            {% for item in props.items %}
            <details class="kb-accordion" style="background: var(--kb-bg); border-radius: var(--kb-radius-md); overflow: hidden; border: 1px solid rgba(100, 116, 139, 0.2); margin-bottom: 0.5rem;">
                <summary style="padding: 1.25rem 1.5rem; font-weight: 600; font-size: 1.1rem; cursor: pointer; color: var(--kb-text-main); display: flex; justify-content: space-between; align-items: center; list-style: none;">
                    {{ item.question }}
                    <span style="color: var(--kb-primary); font-size: 1.5rem; line-height: 1;">+</span>
                </summary>
                <div style="padding: 0 1.5rem 1.5rem; color: var(--kb-text-muted); line-height: 1.6;">
                    {{ item.answer }}
                </div>
            </details>
            {% endfor %}
        </div>
    </div>
</section>
